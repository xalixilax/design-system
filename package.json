{
  "name": "root",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "pnpm": {
    "node-linker": "hoisted"
  },
  "scripts": {
    "prepare": "husky",
    "web": "pnpm --filter web",
    "ui": "pnpm --filter ui",
    "api": "pnpm --filter api",
    "db": "pnpm --filter db",
    "check": "pnpm biome check . --write",
    "check:tokens": "node ./scripts/checkLegacyCssVars.mjs",
    "storybook": "pnpm --filter storybook-doc storybook",
    "lint:types": "pnpm -r exec tsgo --noEmit",
    "ai": "pnpm  lint && pnpm lint:types && pnpm fallow dead-code --quiet && pnpm fallow dupes --quiet && pnpm fmt",
    "lint": "pnpm oxlint",
    "lint:fix": "pnpm oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "^1.3.2",
    "@types/react": "19.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "fallow": "^2.40.3",
    "@typescript/native-preview": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm lint"
  }
